// ============================================================================
// QUICK REFERENCE: NPM PACKAGE MANIFEST
// ============================================================================
// | KEY / CONCEPT      | DESCRIPTION                                                                 |
// |--------------------|-----------------------------------------------------------------------------|
// | scripts            | Shortcut commands for CLI tasks (e.g., 'pnpm dev' to start the server).     |
// | dependencies       | Libraries required for the application to run in production.                |
// | devDependencies    | Tools only needed during development (compilers, linters, bundlers).        |
// | peerDependencies   | Requirements the project expects the environment to already have installed. |
// | Radix UI           | Unstyled, accessible UI primitives used as the foundation for components.   |
// | MUI (Material UI)  | A library of pre-designed React components following Material Design.       |
// | Lucide             | A clean, consistent icon library for modern interfaces.                     |
// | Vite               | The build tool and development server providing fast HMR.                   |
// ============================================================================

// ============================================================================
// FILE DOCUMENTATION: package.json
// ============================================================================
// FILE NAME: package.json
//
// WHAT THIS FILE DOES:
// This is the project's central manifest. It manages metadata, scripts, and 
// all third-party libraries (dependencies). It ensures that any developer 
// or server can reproduce the exact environment needed to run the app.
//
// WHAT THE SYSTEM USES IT FOR:
// - PNPM/NPM: Uses it to install and link libraries.
// - Vite/Node.js: Uses it to determine entry points and module types.
// - CI/CD: Uses 'scripts' to build and deploy the application.
//
// MAIN SECTIONS:
// - Metadata & Config: Project identity and module behavior.
// - Scripts: Automation for the development lifecycle.
// - Dependencies: The massive UI and utility ecosystem (Radix, MUI, Motion).
// - Dev & Peer Dependencies: Build tools and version constraints.
// ============================================================================

{
  // ============================================================
  // SECTION: PROJECT METADATA
  // ============================================================
  "name": "calm-command-center",
  
  // Prevents accidental publishing to the public npm registry.
  "private": true,
  "version": "0.0.1",
  
  // "module" enables modern ESM (import/export) syntax globally.
  "type": "module",

  // ============================================================
  // SECTION: AUTOMATION SCRIPTS
  // ============================================================
  "scripts": {
    // Compiles the project for production into the /dist folder.
    "build": "vite build",
    
    // Starts the local development server with hot module replacement.
    "dev": "vite"
  },

  // ============================================================
  // SECTION: PRODUCTION DEPENDENCIES (RUNTIME)
  // ============================================================
  "dependencies": {
    // Styling engines for MUI and custom styled components.
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    
    // Material UI components and icons for rapid dashboard building.
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    
    // Positioning engine for tooltips and dropdowns.
    "@popperjs/core": "2.11.8",
    
    // --------------------------------------------------------
    // RADIX UI PRIMITIVES
    // Provides accessible, unstyled logic for UI components.
    // --------------------------------------------------------
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    
    // --------------------------------------------------------
    // UI UTILITIES & ANIMATION
    // --------------------------------------------------------
    
    // Helps manage conditional Tailwind classes efficiently.
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    
    // Accessible command menu (palette) for the command center.
    "cmdk": "1.1.1",
    
    // Modern date manipulation library.
    "date-fns": "3.6.0",
    
    // Lightweight carousel functionality for React.
    "embla-carousel-react": "8.6.0",
    
    // Specialized input for One-Time Passwords.
    "input-otp": "1.4.2",
    
    // Standard icon set used across the application.
    "lucide-react": "0.487.0",
    
    // High-performance animation engine (formerly Framer Motion).
    "motion": "12.23.24",
    
    // Theme management (Dark/Light mode) for Next.js and React.
    "next-themes": "0.4.6",
    
    // Specialized UI components for date selection and drag-and-drop.
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    
    // Robust form management and validation logic.
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    
    // Layout tools for split-screen and masonry grids.
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    
    // Slider/Carousel component.
    "react-slick": "0.31.0",
    
    // Data visualization and charting library.
    "recharts": "2.15.2",
    
    // Elegant toast notifications.
    "sonner": "2.0.3",
    
    // Resolves Tailwind class conflicts dynamically.
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    
    // Bottom sheets and drawers for mobile/web interfaces.
    "vaul": "1.1.2"
  },

  // ============================================================
  // SECTION: DEVELOPMENT DEPENDENCIES (BUILD TIME)
  // ============================================================
  "devDependencies": {
    // Tailwind v4 integration for the Vite build pipeline.
    "@tailwindcss/vite": "4.1.12",
    
    // Type definitions for React and the DOM (TypeScript support).
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    
    // React plugin for Vite to handle JSX and Fast Refresh.
    "@vitejs/plugin-react": "4.7.0",
    
    // Utility-first CSS framework (v4).
    "tailwindcss": "4.1.12",
    
    // The language compiler to ensure type-safety across the project.
    "typescript": "^6.0.2",
    
    // The fast build tool and dev server powering the project.
    "vite": "6.3.5"
  },

  // ============================================================
  // SECTION: PEER DEPENDENCIES
  // ============================================================
  
  // These are core libraries that must be provided by the host environment.
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  
  // Marks peer dependencies as optional to avoid strict installation errors.
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },

  // ============================================================
  // SECTION: PNPM SPECIFIC CONFIGURATION
  // ============================================================
  "pnpm": {
    // Force sub-dependencies to use a specific version of Vite 
    // to ensure build consistency across the entire workspace.
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
